{
    // F5 = build debug firmware + flash + attach. Breakpoints in .mojo
    // files, stepping, registers, memory and the RP2040 SVD all work.
    //
    // Why "attach" and not "launch": probe-rs's launch flow arms
    // breakpoints while the RP2040 core is halted in the bootrom, where
    // they never take effect (verified upstream bug — breakpoints set
    // while the core runs application code hit every time). The
    // preLaunchTask does the flashing instead, then we attach.
    "version": "0.2.0",
    "configurations": [
        {
            // Pico 2 / RP2350 (Hazard3 RISC-V). Needs the
            // raspberrypi/openocd fork in ~/.local/bin (README) and
            // gdb-multiarch. Flash happens in the preLaunchTask over
            // SWD (no BOOTSEL); openocd is auto-started as the debug
            // server. Breakpoints in flash need the hardware triggers
            // (4 per core), hence "require".
            "preLaunchTask": "inmojomni: build+flash rp2350 (debug)",
            "type": "cppdbg",
            "request": "launch",
            "name": "inmojomni Pico 2 (RISC-V flash + debug)",
            "cwd": "${workspaceFolder}",
            "program": "${workspaceFolder}/build/main_rp2350_debug.elf",
            "miDebuggerPath": "gdb-multiarch",
            "miDebuggerServerAddress": "localhost:3333",
            "debugServerPath": "${env:HOME}/.local/bin/openocd",
            "debugServerArgs": "-f interface/cmsis-dap.cfg -c \"adapter speed 1000\" -f target/rp2350-riscv.cfg",
            "serverStarted": "Listening on port 3333",
            "filterStderr": true,
            "stopAtEntry": false,
            "hardwareBreakpoints": { "require": true, "limit": 4 },
            "postRemoteConnectCommands": [
                { "text": "monitor reset halt" }
            ]
        },

        {
            "preLaunchTask": "inmojomni: build+flash (debug)",
            "type": "probe-rs-debug",
            "request": "attach",
            "name": "inmojomni (flash + debug)",
            "cwd": "${workspaceFolder}",
            "chip": "rp2040",
            "connectUnderReset": false,
            "speed": 4000,
            "runtimeExecutable": "probe-rs",
            "runtimeArgs": [
                "dap-server"
            ],
            "coreConfigs": [
                {
                    "coreIndex": 0,
                    "programBinary": "${workspaceFolder}/build/firmware-debug.elf",
                    "svdFile": "${workspaceFolder}/.vscode/rp2040.svd"
                }
            ],
            "consoleLogLevel": "Info",
            "wireProtocol": "Swd"
        },
        {
            // Upstream-bug repro config: breakpoints set before start
            // will NOT hit (toggle them once after it stops to fix).
            "preLaunchTask": "inmojomni: build-debug",
            "type": "probe-rs-debug",
            "request": "launch",
            "name": "inmojomni (launch — probe-rs BP bug, avoid)",
            "cwd": "${workspaceFolder}",
            "chip": "rp2040",
            "connectUnderReset": false,
            "speed": 4000,
            "runtimeExecutable": "probe-rs",
            "runtimeArgs": [
                "dap-server"
            ],
            "flashingConfig": {
                "flashingEnabled": true,
                "haltAfterReset": true
            },
            "coreConfigs": [
                {
                    "coreIndex": 0,
                    "programBinary": "${workspaceFolder}/build/firmware-debug.elf",
                    "svdFile": "${workspaceFolder}/.vscode/rp2040.svd"
                }
            ],
            "consoleLogLevel": "Info",
            "wireProtocol": "Swd"
        }
    ]
}
